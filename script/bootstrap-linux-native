#!/usr/bin/env bash
# Bootstrap a native Debian-based setup (with Python 3.13) similar to the devcontainer.
# - Verifies Debian-like environment and Python 3.13
# - Ensures git submodules are initialized and up to date
# - Ensures `uv` is available (installs if missing)
# - Creates/uses a local virtualenv (.venv)
# - Delegates dependency installation to existing scripts where possible
# - Installs additional developer/test requirements used by the devcontainer

set -Eeuo pipefail

# Move to repo root
ROOT_DIR="$(realpath "$(dirname "$0")/..")"
cd "$ROOT_DIR"

log() { printf "\033[1;36m==> %s\033[0m\n" "$*"; }
warn() { printf "\033[1;33m[WARN] %s\033[0m\n" "$*"; }
err()  { printf "\033[1;31m[ERR]  %s\033[0m\n" "$*"; }

APT_UPDATED=0

apt_get_install() {
  if ! command -v apt-get >/dev/null 2>&1; then
    return 1
  fi

  local sudo_cmd=()
  if command -v sudo >/dev/null 2>&1; then
    sudo_cmd=(sudo)
  fi

  if [[ "${APT_UPDATED}" -eq 0 ]]; then
    log "Updating apt package index..."
    "${sudo_cmd[@]}" apt-get update -y
    APT_UPDATED=1
  fi

  local packages=("$@")
  log "Installing packages via apt-get: ${packages[*]}"
  DEBIAN_FRONTEND=noninteractive "${sudo_cmd[@]}" apt-get install -y --no-install-recommends "${packages[@]}"
}

# Detect Debian-like OS (best-effort)
if [[ -f /etc/os-release ]]; then
  . /etc/os-release || true
  if [[ ${ID:-} != "debian" && ${ID_LIKE:-} != *debian* ]]; then
    warn "This script targets Debian-based systems. Detected: ID=${ID:-n/a} ID_LIKE=${ID_LIKE:-n/a}"
  fi
else
  warn "/etc/os-release not found. Skipping OS check."
fi

# Require python3.13
if ! command -v python3 >/dev/null 2>&1; then
  err "python3 not found. Please install Python 3.13 (e.g., 'sudo apt-get install python3.13 python3.13-venv')."
  exit 1
fi
PY_MINOR=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
if [[ "$PY_MINOR" != "3.13" ]]; then
  warn "Detected Python ${PY_MINOR}. This script assumes Python 3.13. Proceeding anyway."
fi

# Make sure git submodules are in place before installing deps that may rely on them
log "Syncing git submodules..."
# Sync URLs first (in case remotes changed)
if command -v git >/dev/null 2>&1; then
  git submodule sync --recursive || true
  git submodule update --init --recursive
  # Attempt to pull latest submodule commits if tracking a branch
  git submodule update --remote --merge --recursive || true
else
  warn "git not found; skipping submodule update."
fi

# Ensure a virtual environment exists and is active
if [[ ! -d .venv ]]; then
  log "Creating Python virtual environment in .venv (python3 -m venv)..."
  python3 -m venv .venv
fi
# shellcheck source=/dev/null
source .venv/bin/activate

# Ensure uv is available (install locally for the current user if missing)
if ! command -v uv >/dev/null 2>&1; then
  log "Installing uv (package manager) for current user..."
  if ! command -v curl >/dev/null 2>&1; then
    if apt_get_install curl; then
      :
    else
      err "Neither 'uv' nor 'curl' available. Please install 'uv' manually."
      exit 1
    fi
  fi
  curl -LsSf https://astral.sh/uv/install.sh | sh
  # Common install locations for uv
  export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.uv/bin:$PATH"
fi

# Verify uv in PATH now
if ! command -v uv >/dev/null 2>&1; then
  err "uv not found in PATH after installation. Ensure ~/.local/bin or ~/.cargo/bin is on PATH."
  exit 1
fi

# Ensure socat is available for serial tests
if ! command -v socat >/dev/null 2>&1; then
  if apt_get_install socat; then
    :
  else
    warn "socat not found and could not be installed automatically. Serial simulator tests may fail."
  fi
fi

log "Installing core development dependencies via existing bootstrap script..."
# Leverage the existing script to mirror devcontainer behavior
./script/bootstrap

log "Installing additional developer/test requirements used by devcontainer..."
# Match tasks in .vscode/tasks.json-like setup
# - All runtime requirements (superset; heavy, but aligns with devcontainer capability)
if [[ -f requirements_all.txt ]]; then
  uv pip install -r requirements_all.txt
fi
# - All test requirements (ensures full test matrix capability)
if [[ -f requirements.txt && -f requirements_test_all.txt ]]; then
  uv pip install -r requirements.txt -r requirements_test_all.txt
fi
# - pytest-homeassistant-custom-component (installed separately in the devcontainer)
log "Ensuring pytest-homeassistant-custom-component is available..."
uv pip install --prerelease=allow --no-deps pytest-homeassistant-custom-component
# - Pre-commit tooling (for linting/hooks like in devcontainer)
if [[ -f requirements_test_pre_commit.txt ]]; then
  uv pip install -r requirements_test_pre_commit.txt || true
fi

log "Installing submodule patch git hook..."
./script/install-submodule-hooks.sh

log "Bootstrap complete. Active environment: $(python -c 'import sys; print(sys.executable)')"
log "Tip: Activate later with 'source .venv/bin/activate' before running tasks."
